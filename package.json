{
  "name": "sentinel-intelligence-vault",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace @siv/web run dev",
    "dev:api": "npm --workspace @siv/api run dev",
    "build": "npm-run-all build:db build:api build:web",
    "build:db": "npm --workspace @siv/database run generate",
    "build:api": "npm --workspace @siv/api run build",
    "build:web": "npm --workspace @siv/web run build",
    "lint": "npm-run-all lint:*",
    "lint:web": "npm --workspace @siv/web run lint",
    "lint:api": "npm --workspace @siv/api run lint",
    "db:generate": "npm --workspace @siv/database run generate",
    "db:migrate": "npm --workspace @siv/database run migrate",
    "db:seed": "npm --workspace @siv/database run seed",
    "start:api": "npm --workspace @siv/api run start",
    "start:web": "npm --workspace @siv/web run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.11.1"
  }
}
